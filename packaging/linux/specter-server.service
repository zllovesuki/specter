[Unit]
Description=Specter server
After=network-online.target
Wants=network-online.target
ConditionPathExists=/etc/specter/server.env

[Service]
Type=simple
User=specter
Group=specter
WorkingDirectory=/var/lib/specter
ExecStart=/usr/libexec/specter/server-launch
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
